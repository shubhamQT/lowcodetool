{
  "id": "add-product-to-cart",
  "testPlanId": "43cdefd4-7b01-482f-8cc2-58a703c3d430",
  "requirementId": "4eb80c5c-67e3-476f-84bb-f0f87c047b29",
  "suiteName": "shubham-amazon-smoke",
  "case": {
    "id": "add-product-to-cart",
    "title": "Add product to cart from product detail page",
    "priority": "P0",
    "platforms": [
      "chrome",
      "firefox",
      "safari",
      "edge"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step-1",
        "action": "openUrl",
        "targetDescription": "Navigate to Amazon India homepage",
        "value": "https://www.amazon.in/"
      },
      {
        "id": "step-2",
        "action": "fill",
        "targetDescription": "Enter product name in search bar",
        "locatorHint": "id=twotabsearchtextbox",
        "value": "samsung s26 ultra"
      },
      {
        "id": "step-3",
        "action": "tap",
        "targetDescription": "Click search button",
        "locatorHint": "id=nav-search-submit-button"
      },
      {
        "id": "step-4",
        "action": "tap",
        "targetDescription": "Click first product in search results",
        "locatorHint": "css=[data-component-type='s-search-result']:first-child h2 a"
      },
      {
        "id": "step-5",
        "action": "tap",
        "targetDescription": "Click Add to Cart button",
        "locatorHint": "id=add-to-cart-button"
      },
      {
        "id": "step-6",
        "action": "assertVisible",
        "targetDescription": "Verify confirmation message or cart count is updated",
        "locatorHint": "id=nav-cart-count"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
