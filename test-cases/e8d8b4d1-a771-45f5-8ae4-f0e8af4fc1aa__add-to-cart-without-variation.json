  "suiteName": "shubham-amazon-negative",
  "case": {
    "id": "add-to-cart-without-variation",
    "title": "Attempt to add to cart without selecting required variation",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "open-homepage",
        "action": "openUrl",
        "targetDescription": "Navigate to Amazon India homepage",
        "value": "https://www.amazon.in/"
      },
      {
        "id": "fill-search-bar",
        "action": "fill",
        "targetDescription": "Enter product name in search bar",
        "locatorHint": "input#twotabsearchtextbox",
        "value": "samsung s26 ultra"
      },
      {
        "id": "tap-search-button",
        "action": "tap",
        "targetDescription": "Click the search button",
        "locatorHint": "input#nav-search-submit-button"
      },
      {
        "id": "tap-first-product",
        "action": "tap",
        "targetDescription": "Click the first product in search results",
        "locatorHint": ".s-main-slot .s-result-item[data-index='1'] h2 a"
      },
      {
        "id": "tap-add-to-cart",
        "action": "tap",
        "targetDescription": "Click Add to Cart without selecting required variation",
        "locatorHint": "#add-to-cart-button"
      },
      {
        "id": "assert-variation-error",
        "action": "assertVisible",
        "targetDescription": "Check for error message about selecting variation",
        "locatorHint": "#variation-error, .a-alert-content"
