{
  "id": "invalid-product-search",
  "testPlanId": "2a5e83cc-13d6-4d7a-a5f6-7616db73f744",
  "requirementId": "4eb80c5c-67e3-476f-84bb-f0f87c047b29",
  "suiteName": "shubham-amazon-negative",
  "case": {
    "id": "invalid-product-search",
    "title": "Search for a non-existent product should show no results",
    "priority": "P1",
    "platforms": [
      "chrome",
      "firefox",
      "safari",
      "edge"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Open Amazon India homepage",
        "value": "https://www.amazon.in/"
      },
      {
        "id": "step2",
        "action": "fill",
        "targetDescription": "Enter gibberish in search bar",
        "locatorHint": "input#twotabsearchtextbox",
        "value": "42425346576876869797979798685"
      },
      {
        "id": "step3",
        "action": "tap",
        "targetDescription": "Click search button",
        "locatorHint": "input#nav-search-submit-button"
      },
      {
        "id": "step4",
        "action": "assertText",
        "targetDescription": "Check for no results message",
        "locatorHint": "div.s-no-results-section, span.a-color-state",
        "assertion": "did not match any products"
      }
    ],
    "tags": [
      "@negative",
      "@regression"
    ]
  }
}
