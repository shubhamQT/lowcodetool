{
  "id": "product-variation-selection",
  "testPlanId": "a379c382-ed2f-42f1-a472-81540563fdd3",
  "requirementId": "4eb80c5c-67e3-476f-84bb-f0f87c047b29",
  "suiteName": "shubham-amazon-e2e",
  "case": {
    "id": "product-variation-selection",
    "title": "User can select product variations before adding to cart",
    "priority": "P1",
    "platforms": [
      "chrome",
      "edge"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Open Amazon India homepage",
        "value": "https://www.amazon.in/"
      },
      {
        "id": "step2",
        "action": "fill",
        "targetDescription": "Enter product name in search bar",
        "locatorHint": "id=twotabsearchtextbox",
        "value": "samsung s26 ultra"
      },
      {
        "id": "step3",
        "action": "tap",
        "targetDescription": "Click search button",
        "locatorHint": "id=nav-search-submit-button"
      },
      {
        "id": "step4",
        "action": "tap",
        "targetDescription": "Click first product in results",
        "locatorHint": "data-component-type=s-search-result"
      },
      {
        "id": "step5",
        "action": "selectOption",
        "targetDescription": "Select product color if available",
        "locatorHint": "name=color_name_0",
        "value": "Black"
      },
      {
        "id": "step6",
        "action": "selectOption",
        "targetDescription": "Select product size if available",
        "locatorHint": "name=size_name_0",
        "value": "256GB"
      },
      {
        "id": "step7",
        "action": "tap",
        "targetDescription": "Click Add to Cart button",
        "locatorHint": "id=add-to-cart-button"
      },
      {
        "id": "step8",
        "action": "assertVisible",
        "targetDescription": "Confirmation message for add to cart",
        "locatorHint": "id=sw-gtc"
      }
    ],
    "tags": [
      "@e2e",
      "@regression"
    ]
  }
}
