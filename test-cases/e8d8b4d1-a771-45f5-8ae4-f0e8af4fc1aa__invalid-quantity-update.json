{
  "id": "invalid-quantity-update",
  "testPlanId": "e8d8b4d1-a771-45f5-8ae4-f0e8af4fc1aa",
  "requirementId": "4eb80c5c-67e3-476f-84bb-f0f87c047b29",
  "suiteName": "shubham-amazon-negative",
  "case": {
    "id": "invalid-quantity-update",
    "title": "Update cart with invalid quantity should show error",
    "priority": "P2",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "open-homepage",
        "action": "openUrl",
        "targetDescription": "Navigate to Amazon India homepage",
        "value": "https://www.amazon.in/"
      },
      {
        "id": "fill-search-bar",
        "action": "fill",
        "targetDescription": "Enter product name in search bar",
        "locatorHint": "input#twotabsearchtextbox",
        "value": "samsung s26 ultra"
      },
      {
        "id": "tap-search-button",
        "action": "tap",
        "targetDescription": "Click the search button",
        "locatorHint": "input#nav-search-submit-button"
      },
      {
        "id": "tap-first-product",
        "action": "tap",
        "targetDescription": "Click the first product in search results",
        "locatorHint": ".s-main-slot .s-result-item[data-index='1'] h2 a"
      },
      {
        "id": "tap-add-to-cart",
        "action": "tap",
        "targetDescription": "Click Add to Cart",
        "locatorHint": "#add-to-cart-button"
      },
      {
        "id": "tap-cart-icon",
        "action": "tap",
        "targetDescription": "Click cart icon to go to cart page",
        "locatorHint": "#nav-cart"
      },
      {
        "id": "fill-invalid-quantity",
        "action": "fill",
        "targetDescription": "Enter invalid quantity (e.g., 0 or -1)",
        "locatorHint": "input[name='quantityBox']",
        "value": "0"
      },
      {
        "id": "tap-update-button",
        "action": "tap",
        "targetDescription": "Click update button",
        "locatorHint": "input[name='submit.update-quantity']"
      },
      {
        "id": "assert-quantity-error",
        "action": "assertVisible",
        "targetDescription": "Check for error message about invalid quantity",
        "locatorHint": ".a-alert-content, .sc-update-quantity-alert"
      }
    ],
    "tags": [
      "@negative",
      "@regression"
    ]
  }
}
