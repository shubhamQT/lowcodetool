{
  "id": "add-to-cart-without-variation",
  "testPlanId": "2a5e83cc-13d6-4d7a-a5f6-7616db73f744",
  "requirementId": "4eb80c5c-67e3-476f-84bb-f0f87c047b29",
  "suiteName": "shubham-amazon-negative",
  "case": {
    "id": "add-to-cart-without-variation",
    "title": "Add to cart without selecting required variation should show error",
    "priority": "P0",
    "platforms": [
      "chrome",
      "firefox",
      "safari",
      "edge"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Open Amazon India homepage",
        "value": "https://www.amazon.in/"
      },
      {
        "id": "step2",
        "action": "fill",
        "targetDescription": "Search for a product with variations",
        "locatorHint": "input#twotabsearchtextbox",
        "value": "t-shirt"
      },
      {
        "id": "step3",
        "action": "tap",
        "targetDescription": "Click search button",
        "locatorHint": "input#nav-search-submit-button"
      },
      {
        "id": "step4",
        "action": "tap",
        "targetDescription": "Click on first product in results",
        "locatorHint": "div.s-main-slot div[data-index='1'] h2 a"
      },
      {
        "id": "step5",
        "action": "tap",
        "targetDescription": "Click Add to Cart without selecting size/color",
        "locatorHint": "input#add-to-cart-button"
      },
      {
        "id": "step6",
        "action": "assertVisible",
        "targetDescription": "Check for variation selection error message",
        "locatorHint": "div#variation_error_message"
      }
    ],
    "tags": [
      "@negative",
      "@regression"
    ]
  }
}
